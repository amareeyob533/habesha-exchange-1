// Habesha Exchange — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id              String   @id @default(cuid())
  uid             String   @unique // 6-digit unique user id
  email           String   @unique
  username        String?  @unique // unique display name (required for new signups)
  name            String?
  passwordHash    String?  // null for google users
  provider        String   @default("credentials") // credentials | google
  avatarUrl       String?
  isBlocked       Boolean  @default(false) // admin can block an account
  blockedReason   String?
  kycLevel        String   @default("none") // none | normal | high
  kycStatus       String   @default("none") // none | pending | approved | rejected
  kycSubmittedAt  DateTime?
  kycRequestedLevel String? // normal | high (the level the user applied for)
  kycDocUrl       String?  // ID card photo (high KYC)
  kycSelfieUrl    String?  // captured selfie photo frame (normal + high)
  kycSelfieVideoUrl String? // live camera video recording (normal + high)
  country         String?
  phone           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  balances             Balance[]
  transactions         Transaction[]
  deposits             Deposit[]
  withdrawals          Withdrawal[]
  transfersSent        Transfer[]    @relation("TransferFrom")
  transfersReceived    Transfer[]    @relation("TransferTo")
  notifications        Notification[]
  supportMessages      SupportMessage[]
  kycMedia             KycMedia[]
}

model Balance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   // USDT | USDC | BTC | TON | HABESHA
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // deposit | withdraw | transfer_in | transfer_out | airdrop
  token           String
  amount          Float
  status          String   @default("completed") // pending | completed | failed
  counterpartyUid String?  // for internal transfers
  network         String?
  address         String?
  note            String?
  createdAt       DateTime @default(now())
}

model Deposit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  network   String
  amount    Float
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Withdrawal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String
  network     String   // internal | TRON | ETHEREUM | BTC NETWORK | TON NETWORK | bank
  amount      Float
  address     String   // wallet address, target UID, or bank account number
  status      String   @default("pending") // pending | completed | rejected
  // Bank-withdrawal-only fields (null for crypto/internal withdrawals)
  bankName    String?  // CBE | Telebirr | Abay Bank | EMPSA
  accountName String?  // account holder name
  birrAmount  Float?   // ETB equivalent at request time (amount_usd * rate)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transfer {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("TransferTo", fields: [toUserId], references: [id], onDelete: Cascade)
  token       String
  amount      Float
  status      String   @default("completed")
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info | success | warning
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  message   String
  status    String   @default("open") // open | resolved
  createdAt DateTime @default(now())
}

// KYC media storage (base64 fallback when Vercel Blob is not configured).
// On Vercel's read-only filesystem we can't write to /public, so we store
// the captured selfie video + ID photo as base64 data URLs here.
model KycMedia {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // video | image
  mimeType  String
  fileName  String
  data      String   // base64 data URL (data:<mime>;base64,<...>) OR a Blob URL when Blob is configured
  size      Int
  createdAt DateTime @default(now())
}
