// Habesha Exchange — Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  // NOTE: This is "sqlite" for local development / sandbox preview.
  // scripts/build.mjs automatically swaps this to "postgresql" + adds directUrl
  // during the Vercel build (where POSTGRES_PRISMA_URL is available).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  uid             String   @unique // 6-digit unique user id
  email           String   @unique
  username        String?  @unique // unique display name (required for new signups)
  name            String?
  passwordHash    String?  // null for google users
  provider        String   @default("credentials") // credentials | google
  avatarUrl       String?
  isBlocked       Boolean  @default(false) // admin can block an account
  blockedReason   String?
  // KYC (Exness-style 2-step verification)
  kycStatus       String   @default("none") // none | pending | approved | rejected
  kycSubmittedAt  DateTime?
  kycApprovedAt   DateTime? // set when admin approves — used for 2-day auto-delete
  kycFullName     String?  // step 1: full name as written on the ID
  kycCity         String?  // step 1: city where the user lives
  kycIdType       String?  // step 2: driver_license | national_id | passport
  kycRejectReason String?  // filled when admin rejects
  country         String?
  phone           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  balances             Balance[]
  transactions         Transaction[]
  deposits             Deposit[]
  withdrawals          Withdrawal[]
  transfersSent        Transfer[]    @relation("TransferFrom")
  transfersReceived    Transfer[]    @relation("TransferTo")
  notifications        Notification[]
  supportMessages      SupportMessage[]
  buyOrders            BuyOrder[]
  paymentProofs        PaymentProof[]
  kycApplications      KycApplication[]
}

model Balance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   // USDT | USDC | BTC | TON | HABESHA
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String   // deposit | withdraw | transfer_in | transfer_out | airdrop
  token           String
  amount          Float
  status          String   @default("completed") // pending | completed | failed
  counterpartyUid String?  // for internal transfers
  network         String?
  address         String?
  note            String?
  createdAt       DateTime @default(now())
}

model Deposit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  network   String
  amount    Float
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Withdrawal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String
  network     String   // internal | TRON | ETHEREUM | BTC NETWORK | TON NETWORK | bank
  amount      Float
  address     String   // wallet address, target UID, or bank account number
  status      String   @default("pending") // pending | completed | rejected
  // Bank-withdrawal-only fields (null for crypto/internal withdrawals)
  bankName    String?  // CBE | Telebirr | Abay Bank | EMPSA
  accountName String?  // account holder name
  birrAmount  Float?   // ETB equivalent at request time (amount_usd * rate)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transfer {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("TransferTo", fields: [toUserId], references: [id], onDelete: Cascade)
  token       String
  amount      Float
  status      String   @default("completed")
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info | success | warning
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  message   String
  status    String   @default("open") // open | resolved
  createdAt DateTime @default(now())
  replies   SupportReply[]
}

model SupportReply {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportMessage @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String   // user id of sender (could be user or admin)
  senderRole String  // "user" | "admin"
  message   String
  createdAt DateTime @default(now())
}


// Buy USDT orders — users buy USDT with ETB via bank transfer.
model BuyOrder {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usdtAmount      Float
  birrAmount      Float
  rate            Float    // ETB per USDT at order time
  bank            String   // CBE | Telebirr | Abay Bank | EMPSA
  screenshotUrl   String?  // payment proof screenshot
  transactionCode String?  // optional bank transaction code
  status          String   @default("pending") // pending | approved | rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Payment proof screenshots for buy orders (base64 storage).
model PaymentProof {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mimeType  String
  fileName  String
  data      String   // base64 data URL or external URL
  size      Int
  createdAt DateTime @default(now())
}

// ============================================================================
// KYC (Exness-style 2-step verification)
// ============================================================================
// A user submits full name + city (step 1) and an ID photo (step 2).
// The application goes to "pending" until an admin approves/rejects it.
// Approved users get unlimited deposits/withdrawals; unapproved users are
// capped at 500 USD lifetime deposit value.
//
// RETENTION POLICY: When the admin approves a KYC, the ID document is kept
// for exactly 2 days (so the admin can still review/download it), then
// automatically deleted. Rejection deletes the document immediately.
// Auto-deletion is handled lazily by /api/kyc/* routes (see cleanupExpiredKyc).
model KycApplication {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String   // step 1
  city        String   // step 1
  idType      String   // step 2: driver_license | national_id | passport
  status      String   @default("pending") // pending | approved | rejected
  rejectReason String?
  submittedAt DateTime @default(now())
  reviewedAt  DateTime? // set when admin acts
  reviewedBy  String?  // admin user id
  documents   KycDocument[]
}

model KycDocument {
  id            String   @id @default(cuid())
  applicationId String
  application   KycApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  side          String   @default("front") // front | back
  mimeType      String
  fileName      String
  data          String   // base64 data URL
  size          Int
  // Auto-delete timestamp. Set to (approvedAt + 2 days) when admin approves.
  // Lazy cleanup: any KYC API call deletes documents past this timestamp.
  deleteAfter   DateTime?
  createdAt     DateTime @default(now())
}

// ============================================================================
// Web Push Notifications
// ============================================================================
// Each user can have multiple push subscriptions (one per device/browser).
// When a notification is created in the DB, we also send a web push to all
// of that user's subscriptions so it shows up as a system notification on
// their phone/desktop even when the tab is closed.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique // the push service endpoint URL (per device)
  p256dh    String   // client public key (base64url)
  auth      String   // auth secret (base64url)
  createdAt DateTime @default(now())
}

// ============================================================================
// User Settings (persisted preferences)
// ============================================================================
// Stores the user's exchange, wallet, and notification preferences so the
// Settings page is functional (not just for show). One row per user.
model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  // Exchange
  defaultToken        String   @default("USDT")
  slippage            Float    @default(1.0)
  showBalanceUsd      Boolean  @default(true)
  compactView         Boolean  @default(false)
  // Wallet
  defaultNetwork      String   @default("TRON (TRC20)")
  autoConvertDust     Boolean  @default(false)
  hideSmallBalances   Boolean  @default(false)
  // Notifications
  emailNotifs         Boolean  @default(true)
  pushNotifs          Boolean  @default(true)
  depositAlerts       Boolean  @default(true)
  withdrawAlerts      Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
